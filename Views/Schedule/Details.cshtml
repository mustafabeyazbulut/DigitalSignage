@model DigitalSignage.Models.Schedule

@{
    var locale = ViewBag.CurrentLocale as string ?? "en";
    var lang = ViewBag.Lang as DigitalSignage.Services.ILanguageService;
    string T(string key) => lang?.Get(locale, key) ?? key;
    ViewData["Title"] = T("schedule.detailsTitle");

    var schedulePages = Model.SchedulePages?.OrderBy(sp => sp.DisplayOrder).ToList()
                        ?? new List<DigitalSignage.Models.SchedulePage>();
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">@Model.ScheduleName</h2>
        <div>
            <a href="/Display/Schedule/@Model.ScheduleID" target="_blank" class="btn btn-success">
                <i class="bi bi-display me-1"></i> @T("page.preview")
            </a>
            <a asp-action="Edit" asp-route-id="@Model.ScheduleID" class="btn btn-warning">
                <i class="fas fa-edit me-1"></i> @T("common.edit")
            </a>
            <a asp-action="Delete" asp-route-id="@Model.ScheduleID" class="btn btn-danger">
                <i class="fas fa-trash me-1"></i> @T("common.delete")
            </a>
            <button type="button" class="btn btn-outline-secondary ms-1" data-smart-back="@ViewBag.BreadcrumbBackUrl">
                <i class="fas fa-arrow-left me-1"></i> @T("common.backToList")
            </button>
        </div>
    </div>

    <div class="row">
        <!-- Sol: Bilgiler + Özet -->
        <div class="col-lg-3">
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>@T("schedule.scheduleInfo")</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">@T("schedule.scheduleName")</dt>
                        <dd class="col-sm-7">@Model.ScheduleName</dd>

                        <dt class="col-sm-5">@T("common.company")</dt>
                        <dd class="col-sm-7">@Model.Company?.CompanyName</dd>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <dt class="col-sm-5">@T("company.description")</dt>
                            <dd class="col-sm-7">@Model.Description</dd>
                        }

                        <dt class="col-sm-5">@T("common.status")</dt>
                        <dd class="col-sm-7">
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                @(Model.IsActive ? T("common.active") : T("common.inactive"))
                            </span>
                        </dd>

                        <dt class="col-sm-5">@T("common.createdDate")</dt>
                        <dd class="col-sm-7">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>

        </div>

        <!-- Sağ: Playlist -->
        <div class="col-lg-9">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-list-ol me-2"></i>@T("schedule.playlist")</h5>
                </div>
                <div class="card-body p-0">
                    @if (schedulePages.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:60px;">#</th>
                                    <th>@T("page.pageName")</th>
                                    <th>@T("common.department")</th>
                                    <th>@T("page.layout")</th>
                                    <th style="width:120px;">@T("schedule.duration")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sp in schedulePages)
                                {
                                    <tr>
                                        <td><span class="badge bg-secondary rounded-pill">@sp.DisplayOrder</span></td>
                                        <td>
                                            <div class="fw-bold">@sp.Page?.PageName</div>
                                            <small class="text-muted">@sp.Page?.PageTitle</small>
                                        </td>
                                        <td><span class="badge bg-light text-dark">@sp.Page?.Department?.DepartmentName</span></td>
                                        <td>
                                            @if (sp.Page?.Layout != null)
                                            {
                                                <span class="badge bg-info text-dark">@sp.Page.Layout.LayoutName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td><span class="fw-bold">@sp.DisplayDuration</span> @T("schedule.sec")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2"></i>
                            <p>@T("schedule.emptyPlaylist")</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
