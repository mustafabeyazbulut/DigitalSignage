@{
    var locale = ViewBag.CurrentLocale as string ?? "en";
    var lang = ViewBag.Lang as DigitalSignage.Services.ILanguageService;
    string T(string key) => lang?.Get(locale, key) ?? key;
    ViewData["Title"] = T("nav.dashboard");

    var recentPages = ViewBag.RecentPages as List<DigitalSignage.Models.Page> ?? new List<DigitalSignage.Models.Page>();
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold text-dark">@T("dashboard.welcomeBack")</h2>
        <p class="text-muted">@T("dashboard.subtitle")</p>
    </div>
</div>

@if (ViewBag.HasAnyRole != true)
{
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center py-5">
                    <i class="fas fa-user-clock fa-3x text-muted mb-3"></i>
                    <h4 class="fw-bold text-dark">@T("dashboard.noRoleTitle")</h4>
                    <p class="text-muted mb-0">@T("dashboard.noRoleMessage")</p>
                </div>
            </div>
        </div>
    </div>
}
else
{

<!-- İstatistik Kartları -->
<div class="row g-4 mb-4">
    @if (ViewBag.IsSystemAdmin == true)
    {
        <div class="col-md-4 col-lg">
            <a asp-controller="Company" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-start border-4 border-primary shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="text-uppercase text-muted fw-bold mb-0">@T("dashboard.totalCompanies")</h6>
                            <span class="text-primary"><i class="fas fa-building fa-lg"></i></span>
                        </div>
                        <h2 class="display-6 fw-bold mb-0 text-dark">@ViewBag.CompanyCount</h2>
                    </div>
                </div>
            </a>
        </div>
    }
    <div class="col-md-4 col-lg">
        <a asp-controller="Layout" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-start border-4 border-success shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-uppercase text-muted fw-bold mb-0">@T("dashboard.layouts")</h6>
                        <span class="text-success"><i class="fas fa-th-large fa-lg"></i></span>
                    </div>
                    <h2 class="display-6 fw-bold mb-0 text-dark">@ViewBag.LayoutCount</h2>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-lg">
        <a asp-controller="Content" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-start border-4 border-info shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-uppercase text-muted fw-bold mb-0">@T("dashboard.mediaLibrary")</h6>
                        <span class="text-info"><i class="fas fa-photo-video fa-lg"></i></span>
                    </div>
                    <h2 class="display-6 fw-bold mb-0 text-dark">@ViewBag.ContentCount</h2>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-lg">
        <a asp-controller="Page" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-start border-4 border-warning shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-uppercase text-muted fw-bold mb-0">@T("dashboard.pages")</h6>
                        <span class="text-warning"><i class="fas fa-file-alt fa-lg"></i></span>
                    </div>
                    <h2 class="display-6 fw-bold mb-0 text-dark">@ViewBag.PageCount</h2>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4 col-lg">
        <a asp-controller="Schedule" asp-action="Index" class="text-decoration-none">
            <div class="card h-100 border-start border-4 border-danger shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="text-uppercase text-muted fw-bold mb-0">@T("dashboard.schedules")</h6>
                        <span class="text-danger"><i class="fas fa-calendar-alt fa-lg"></i></span>
                    </div>
                    <h2 class="display-6 fw-bold mb-0 text-dark">@ViewBag.ScheduleCount</h2>
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Son Eklenen Sayfalar & Hızlı İşlemler -->
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock me-2"></i>@T("dashboard.recentPages")</h6>
                <a asp-controller="Page" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill">@T("common.viewAll")</a>
            </div>
            <div class="card-body p-0">
                @if (recentPages.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">@T("page.pageName")</th>
                                    <th>@T("common.department")</th>
                                    <th>@T("page.layout")</th>
                                    <th>@T("common.status")</th>
                                    <th>@T("common.createdDate")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pg in recentPages)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <a asp-controller="Page" asp-action="Details" asp-route-id="@pg.PageID" class="fw-bold text-decoration-none">
                                                @pg.PageName
                                            </a>
                                            @if (!string.IsNullOrEmpty(pg.PageTitle))
                                            {
                                                <br /><small class="text-muted">@pg.PageTitle</small>
                                            }
                                        </td>
                                        <td><span class="badge bg-light text-dark">@pg.Department?.DepartmentName</span></td>
                                        <td>
                                            @if (pg.Layout != null)
                                            {
                                                <span class="badge bg-info text-dark">@pg.Layout.LayoutName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(pg.IsActive ? "bg-success" : "bg-danger") rounded-pill">
                                                @(pg.IsActive ? T("common.active") : T("common.inactive"))
                                            </span>
                                        </td>
                                        <td class="text-muted">@pg.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-file-alt fa-2x mb-2"></i>
                        <p class="mb-0">@T("dashboard.noPagesYet")</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="m-0 fw-bold text-secondary"><i class="fas fa-bolt me-2"></i>@T("dashboard.quickActions")</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    @if (ViewBag.IsSystemAdmin == true || ViewBag.IsCompanyAdmin == true)
                    {
                        <a asp-controller="Layout" asp-action="Create" class="btn btn-outline-success shadow-sm text-start py-3">
                            <i class="fas fa-th-large me-3 fa-lg"></i> @T("dashboard.newLayout")
                        </a>
                        <a asp-controller="Content" asp-action="Create" class="btn btn-primary shadow-sm text-start py-3">
                            <i class="fas fa-upload me-3 fa-lg"></i> @T("dashboard.uploadContent")
                        </a>
                        <a asp-controller="Page" asp-action="Create" class="btn btn-outline-warning shadow-sm text-start py-3">
                            <i class="fas fa-file-alt me-3 fa-lg"></i> @T("dashboard.createPage")
                        </a>
                        <a asp-controller="Schedule" asp-action="Create" class="btn btn-outline-danger shadow-sm text-start py-3">
                            <i class="fas fa-calendar-alt me-3 fa-lg"></i> @T("dashboard.newSchedule")
                        </a>
                    }
                    @if (ViewBag.IsSystemAdmin == true)
                    {
                        <a asp-controller="Company" asp-action="Create" class="btn btn-light shadow-sm text-start py-3 border">
                            <i class="fas fa-building me-3 fa-lg"></i> @T("dashboard.addCompany")
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

} <!-- end hasAnyRole -->
