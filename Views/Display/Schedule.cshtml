@model DigitalSignage.Models.Schedule
@using System.Text.Json
@{
    Layout = null;
    var schedulePages = Model.SchedulePages
        .Where(sp => sp.IsActive && sp.Page != null && sp.Page.IsActive)
        .OrderBy(sp => sp.DisplayOrder)
        .ToList();
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.ScheduleName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100vw; height: 100vh; overflow: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #000; }

        /* Toolbar — her zaman görünür */
        .schedule-toolbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            height: 48px; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 16px; color: #fff; font-size: 0.9rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .schedule-toolbar .toolbar-left { display: flex; align-items: center; gap: 12px; }
        .schedule-toolbar .toolbar-center { display: flex; align-items: center; gap: 8px; }
        .schedule-toolbar .toolbar-right { display: flex; align-items: center; gap: 12px; }

        .toolbar-btn {
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
            color: #fff; padding: 6px 12px; border-radius: 6px; cursor: pointer;
            font-size: 0.85rem; transition: background 0.2s; display: inline-flex; align-items: center;
        }
        .toolbar-btn:hover { background: rgba(255,255,255,0.25); }
        .toolbar-btn.active { background: rgba(255,193,7,0.3); border-color: #ffc107; }

        .page-indicator { font-weight: 600; min-width: 60px; text-align: center; }
        .current-page-name { font-size: 0.9rem; font-weight: 600; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .next-page-info { font-size: 0.75rem; opacity: 0.6; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

        /* Progress bar */
        .progress-bar-container {
            position: fixed; top: 48px; left: 0; right: 0; height: 3px;
            background: rgba(255,255,255,0.1); z-index: 1001;
        }
        .progress-bar-fill {
            height: 100%; background: #ffc107; width: 0%;
            transition: width 0.1s linear;
        }

        /* iframe'ler — toolbar altında */
        .page-frame {
            position: fixed; top: 51px; left: 0; width: 100%; height: calc(100vh - 51px);
            border: none; background: #000;
            opacity: 0; pointer-events: none; transition: opacity 0.6s ease;
        }
        .page-frame.active { opacity: 1; pointer-events: auto; }

        /* Boş durum */
        .empty-state {
            width: 100%; height: 100%; display: flex; flex-direction: column;
            align-items: center; justify-content: center; color: #fff; gap: 16px;
        }
        .empty-state i { font-size: 4rem; opacity: 0.5; }
        .empty-state h2 { font-size: 1.5rem; opacity: 0.7; }
    </style>
</head>
<body>
    @if (schedulePages.Any())
    {
        <!-- Toolbar -->
        <div class="schedule-toolbar" id="toolbar">
            <div class="toolbar-left">
                <span class="current-page-name" id="currentPageName"></span>
            </div>
            <div class="toolbar-center">
                <button class="toolbar-btn" onclick="prevPage()" title="Önceki Sayfa">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="page-indicator" id="pageIndicator">1 / @schedulePages.Count</span>
                <button class="toolbar-btn" onclick="nextPage()" title="Sonraki Sayfa">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <button class="toolbar-btn" id="btnPause" onclick="togglePause()" title="Duraklat / Devam Et">
                    <i class="bi bi-pause-fill" id="pauseIcon"></i>
                </button>
            </div>
            <div class="toolbar-right">
                <span class="next-page-info" id="nextPageInfo"></span>
                <span id="countdownText" style="opacity:0.7;font-size:0.8rem;min-width:35px;text-align:right;"></span>
                <button class="toolbar-btn" onclick="toggleFullscreen()" title="Tam Ekran">
                    <i class="bi bi-fullscreen"></i>
                </button>
            </div>
        </div>

        <!-- İlerleme çubuğu -->
        <div class="progress-bar-container" id="progressContainer">
            <div class="progress-bar-fill" id="progressFill"></div>
        </div>

        <!-- Sayfa iframe'leri — tümü önceden yüklenir -->
        @for (int i = 0; i < schedulePages.Count; i++)
        {
            var sp = schedulePages[i];
            <iframe
                class="page-frame @(i == 0 ? "active" : "")"
                id="frame-@i"
                src="/Display/@sp.PageID"
                data-page-id="@sp.PageID"
                data-duration="@sp.DisplayDuration"
                loading="eager">
            </iframe>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-collection-play"></i>
            <h2>Bu zamanlamada aktif sayfa bulunmuyor.</h2>
        </div>
    }

    <script>
        var SCHEDULE_ID = @Model.ScheduleID;
        var pages = [
            @foreach (var sp in schedulePages)
            {
                var pageName = System.Web.HttpUtility.JavaScriptStringEncode(sp.Page?.PageTitle ?? sp.Page?.PageName ?? "");
                <text>{ pageId: @sp.PageID, duration: @sp.DisplayDuration, name: '@Html.Raw(pageName)' },</text>
            }
        ];

        var currentIndex = 0;
        var isPaused = false;
        var timer = null;
        var progressTimer = null;
        var progressStart = 0;
        var cycleCount = 0;

        // Sayfa bilgilerini güncelle
        function updatePageInfo(index) {
            var nameEl = document.getElementById('currentPageName');
            var nextEl = document.getElementById('nextPageInfo');
            var indicator = document.getElementById('pageIndicator');

            if (indicator) indicator.textContent = (index + 1) + ' / ' + pages.length;
            if (nameEl) nameEl.textContent = pages[index].name;

            if (nextEl) {
                if (pages.length > 1) {
                    var nextIdx = (index + 1) % pages.length;
                    nextEl.innerHTML = '<i class="bi bi-skip-forward me-1"></i>' + pages[nextIdx].name;
                } else {
                    nextEl.textContent = '';
                }
            }
        }

        // Slideshow
        function showPage(index) {
            var frames = document.querySelectorAll('.page-frame');
            frames.forEach(function(f) { f.classList.remove('active'); });

            var target = document.getElementById('frame-' + index);
            if (target) target.classList.add('active');

            currentIndex = index;
            updatePageInfo(index);
            startTimer();
        }

        function nextPage() {
            var next = (currentIndex + 1) % pages.length;
            // Döngü tamamlandıysa veri güncelle
            if (next === 0) {
                cycleCount++;
                refreshScheduleData();
            }
            showPage(next);
        }

        function prevPage() {
            var prev = (currentIndex - 1 + pages.length) % pages.length;
            showPage(prev);
        }

        function togglePause() {
            isPaused = !isPaused;
            var icon = document.getElementById('pauseIcon');
            var btn = document.getElementById('btnPause');
            if (isPaused) {
                icon.className = 'bi bi-play-fill';
                btn.classList.add('active');
                clearTimeout(timer);
                cancelAnimationFrame(progressTimer);
            } else {
                icon.className = 'bi bi-pause-fill';
                btn.classList.remove('active');
                startTimer();
            }
        }

        function startTimer() {
            clearTimeout(timer);
            cancelAnimationFrame(progressTimer);

            if (isPaused || pages.length === 0) return;

            var duration = pages[currentIndex].duration * 1000;
            progressStart = Date.now();

            function updateProgress() {
                var elapsed = Date.now() - progressStart;
                var pct = Math.min((elapsed / duration) * 100, 100);
                var fill = document.getElementById('progressFill');
                if (fill) fill.style.width = pct + '%';

                var countdown = document.getElementById('countdownText');
                if (countdown) {
                    var remaining = Math.max(0, Math.ceil((duration - elapsed) / 1000));
                    countdown.textContent = remaining + 'sn';
                }

                if (elapsed < duration) {
                    progressTimer = requestAnimationFrame(updateProgress);
                }
            }
            updateProgress();

            timer = setTimeout(function() {
                nextPage();
            }, duration);
        }

        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
            } else {
                document.exitFullscreen();
            }
        }

        // Döngü sonunda schedule verisini yeniden çek
        function refreshScheduleData() {
            fetch('/Display/ScheduleData/' + SCHEDULE_ID)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data.pages || data.pages.length === 0) return;

                    var changed = false;
                    if (data.pages.length !== pages.length) {
                        changed = true;
                    } else {
                        for (var i = 0; i < data.pages.length; i++) {
                            if (data.pages[i].pageId !== pages[i].pageId ||
                                data.pages[i].duration !== pages[i].duration) {
                                changed = true;
                                break;
                            }
                        }
                    }

                    if (changed) {
                        pages = data.pages.map(function(p) {
                            return { pageId: p.pageId, duration: p.duration, name: p.pageName };
                        });
                        rebuildFrames();
                    } else {
                        // Sayfa adları güncellenmiş olabilir
                        for (var i = 0; i < data.pages.length; i++) {
                            pages[i].name = data.pages[i].pageName;
                        }
                        updatePageInfo(currentIndex);
                        reloadFrames();
                    }
                })
                .catch(function(err) {
                    console.warn('Schedule güncelleme hatası:', err);
                });
        }

        function reloadFrames() {
            var frames = document.querySelectorAll('.page-frame');
            frames.forEach(function(f, i) {
                if (i !== currentIndex) {
                    f.src = f.src;
                }
            });
        }

        function rebuildFrames() {
            document.querySelectorAll('.page-frame').forEach(function(f) { f.remove(); });

            pages.forEach(function(p, i) {
                var iframe = document.createElement('iframe');
                iframe.className = 'page-frame' + (i === 0 ? ' active' : '');
                iframe.id = 'frame-' + i;
                iframe.src = '/Display/' + p.pageId;
                iframe.setAttribute('data-page-id', p.pageId);
                iframe.setAttribute('data-duration', p.duration);
                iframe.loading = 'eager';
                document.body.appendChild(iframe);
            });

            currentIndex = 0;
            updatePageInfo(0);
            startTimer();
        }

        // Klavye kısayolları
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowRight') nextPage();
            else if (e.key === 'ArrowLeft') prevPage();
            else if (e.key === ' ') { e.preventDefault(); togglePause(); }
            else if (e.key === 'f' || e.key === 'F') toggleFullscreen();
        });

        // Başlat
        if (pages.length > 0) {
            updatePageInfo(0);
            if (pages.length > 1) {
                startTimer();
            }
        }
    </script>
</body>
</html>
