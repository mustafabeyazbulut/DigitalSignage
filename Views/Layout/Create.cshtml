@model DigitalSignage.Models.Layout

@{
    var locale = ViewBag.CurrentLocale as string ?? "en";
    var lang = ViewBag.Lang as DigitalSignage.Services.ILanguageService;
    string T(string key) => lang?.Get(locale, key) ?? key;
    ViewData["Title"] = T("layout.createTitle");
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">@T("layout.createTitle")</h2>
        <button type="button" class="btn btn-outline-secondary" data-smart-back="@ViewBag.BreadcrumbBackUrl">
            <i class="fas fa-arrow-left me-2"></i> @T("common.backToList")
        </button>
    </div>

    <form asp-action="Create" id="layout-form">
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
        <input type="hidden" asp-for="CompanyID" />
        <input type="hidden" asp-for="LayoutDefinition" id="LayoutDefinition" />

        <div class="row">
            <!-- Sol: Form + Builder Kontrolleri -->
            <div class="col-lg-7">
                <div class="card shadow-sm mb-3">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>@T("layout.layoutInfo")</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="LayoutName" class="form-label fw-bold">@T("layout.layoutName")</label>
                                <input asp-for="LayoutName" class="form-control" placeholder="@T("layout.layoutNamePlaceholder")" />
                                <span asp-validation-for="LayoutName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Description" class="form-label">@T("company.description")</label>
                                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-3">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-th me-2"></i>@T("layout.defineGrid")</h5>
                    </div>
                    <div class="card-body">
                        <div id="layout-builder-controls"></div>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" id="layout-submit-btn" class="btn btn-primary btn-lg">
                        <i class="fas fa-check me-2"></i> @T("common.create")
                    </button>
                </div>
            </div>

            <!-- Sag: Canli Onizleme -->
            <div class="col-lg-5">
                <div class="card shadow-sm" style="position:sticky;top:20px;">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-eye me-2"></i>@T("layout.preview")</h5>
                    </div>
                    <div class="card-body">
                        <div id="layout-preview" class="lb-preview"></div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/layout-builder.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/layout-builder.js" asp-append-version="true"></script>
    <script>
        window.layoutBuilderTranslations = {
            addRow: '@Html.Raw(T("layout.addRow"))',
            removeRow: '@Html.Raw(T("layout.removeRow"))',
            addCol: '@Html.Raw(T("layout.addColumn"))',
            removeCol: '@Html.Raw(T("layout.removeColumn"))',
            height: '@Html.Raw(T("layout.rowHeight"))',
            colTotal: '@Html.Raw(T("layout.columnWidth"))',
            row: '@Html.Raw(T("layout.row"))',
            totalHeight: '@Html.Raw(T("layout.totalHeight"))',
            equalDistribute: '@Html.Raw(T("layout.equalDistribute"))',
            splitCell: '@Html.Raw(T("layout.splitCell"))',
            unsplitCell: '@Html.Raw(T("layout.unsplitCell"))',
            nested: '@Html.Raw(T("layout.nested"))',
            templates: '@Html.Raw(T("layout.templates"))',
            tpl_full: '@Html.Raw(T("layout.tplFull"))',
            tpl_twoCols: '@Html.Raw(T("layout.tplTwoCols"))',
            tpl_twoRows: '@Html.Raw(T("layout.tplTwoRows"))',
            tpl_grid2x2: '@Html.Raw(T("layout.tplGrid2x2"))',
            tpl_headerContent: '@Html.Raw(T("layout.tplHeaderContent"))',
            tpl_sidebar: '@Html.Raw(T("layout.tplSidebar"))',
            tpl_threeCols: '@Html.Raw(T("layout.tplThreeCols"))',
            tpl_threeRows: '@Html.Raw(T("layout.tplThreeRows"))'
        };
        LayoutBuilder.init('@Html.Raw(Model.LayoutDefinition?.Replace("'", "\\'") ?? "{\"rows\":[{\"height\":100,\"columns\":[{\"width\":100}]}]}")');
    </script>
}
